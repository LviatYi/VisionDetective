    {
      "id": 10000501,
      "type": "interactive",
      "params": {
        "type": "dialogue",
        "params": {
          "nodes": [
            {
              "id": 1,
              "source": 1,
              "text": "发生什么事了？"
            },
            {
              "id": 2,
              "source": 2,
              "text": "啊...我听到有人喊救命...卧室死了个人..."
            },
            {
              "id": 3,
              "source": 1,
              "text": "哦？不要慌，我可是职业侦探，我去看看。"
            },
            {
              "id": 4,
              "source": 2,
              "text": "呃...呃..."
            }
          ]
        }
      }
    },
    {
      "id": 10000502,
      "type": "interactive",
      "params": {
        "type": "dialogue",
        "params": {
          "nodes": [
            {
              "id": 1,
              "source": 1,
              "text": "看起来确实发生了命案，但似乎哪里有些不对劲..."
            },
            {
              "id": 2,
              "source": 1,
              "text": "进门的时候，门锁没有撬动的痕迹。"
            },
            {
              "id": 3,
              "source": 1,
              "text": "总之先四处看看吧。"
            }
          ]
        }
      }
    },
